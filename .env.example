# ─── RPC & Chain ────────────────────────────────────────────────────────────
BASE_RPC_URL=https://mainnet.base.org

# ─── Wallet (OWF Local Vault) ────────────────────────────────────────────────
# Never commit a real private key. Use a hardware-backed signer in production.
AGENT_PRIVATE_KEY=0xyour_private_key_here
VAULT_ENCRYPTION_KEY=32-byte-hex-string-for-aes-encryption

# ─── Revenue ─────────────────────────────────────────────────────────────────
ADMIN_REVENUE_WALLET=0xYourRevenueWalletAddress

# ─── AEDC Meter ──────────────────────────────────────────────────────────────
METER_NUMBER=O159006781284
TOPUP_AMOUNT_NGN=5000
NGN_USD_RATE=1600

# ─── VTpass ──────────────────────────────────────────────────────────────────
VTPASS_API_KEY=your_vtpass_api_key
VTPASS_SECRET_KEY=your_vtpass_secret_key
VTPASS_PUBLIC_KEY=your_vtpass_public_key
# Set to "https://sandbox.vtpass.com/api" for testing
VTPASS_BASE_URL=https://vtpass.com/api

# ─── Starknet Frictionless Inflow (Sepolia Testnet) ─────────────────────────
# Optional — if not set, the agent derives keys from AGENT_PRIVATE_KEY
STARKNET_PRIVATE_KEY=0xyour_starknet_private_key
STARKNET_ACCOUNT_ADDRESS=0xyour_starknet_account_address
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io
# Yield check interval in ms (default: 12 hours)
STARKNET_YIELD_CHECK_MS=43200000
# Min yield to trigger harvest (default: 2.0 — STRK for growth, USDC for stability)
STARKNET_STRK_MIN_HARVEST=2.0
# Yield strategy: 'stability' (USDC -> nUSDC) or 'growth' (USDC -> wBTC -> STRK)
STARKNET_YIELD_MODE=growth

# ─── Email Notification ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
NOTIFY_TO=user@example.com
